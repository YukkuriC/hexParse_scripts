{
    "nested_list": {
        "prefix": "[",
        "body": "[${1}]",
        "label": "Nested List",
        "description": "Nested list (ListIota)"
    },
    "paren_pattern": {
        "prefix": "(",
        "body": "(${1})",
        "label": "Paren Pattern",
        "description": "Non-functional pattern wrapper"
    },
    "brace_pattern": {
        "prefix": "{",
        "body": "{${1}}",
        "label": "Brace Pattern",
        "description": "Non-functional pattern wrapper (brace, equivalent to paren)"
    },
    "vec3": {
        "prefix": "vec3",
        "body": "vec_${1:x}_${2:y}_${3:z}",
        "label": "Vector (3-axis)",
        "description": "Vector literal with 3 axes"
    },
    "vec2": {
        "prefix": "vec2",
        "body": "vec_${1:x}_${2:y}",
        "label": "Vector (2-axis)",
        "description": "Vector literal with 2 axes"
    },
    "vec1": {
        "prefix": "vec1",
        "body": "vec_${1:x}",
        "label": "Vector (1-axis)",
        "description": "Vector literal with 1 axis"
    },
    "entity_uuid": {
        "prefix": "entity_",
        "body": "entity_${1:00000000-0000-0000-0000-000000000000}",
        "label": "Entity UUID",
        "description": "Entity reference by UUID"
    },
    "quoted_string": {
        "prefix": "strq",
        "body": "\"${1}\"",
        "label": "Quoted String",
        "description": "Double-quoted string literal"
    },
    "string_prefix": {
        "prefix": "str_",
        "body": "str_${1:content}",
        "label": "String Prefix",
        "description": "String literal with str_ prefix"
    },
    "number_pattern": {
        "prefix": "num_",
        "body": "num_${1:0}",
        "label": "Number Pattern",
        "description": "Numerical Reflection pattern"
    },
    "mask_pattern": {
        "prefix": "mask_",
        "body": "mask_${1:--vv--}",
        "label": "Mask Pattern",
        "description": "Bookkeeper's Gambit mask pattern"
    },
    "raw_pattern": {
        "prefix": "_raw",
        "body": "_${1:wedsaq}",
        "label": "Raw Pattern",
        "description": "Raw pattern by angle signature"
    },
    "macro_ref": {
        "prefix": "#",
        "body": "#${1:macro_name}",
        "label": "Macro Ref",
        "description": "Macro reference"
    },
    "comment_iota": {
        "prefix": "comment_",
        "body": "comment_${1:text}",
        "label": "Comment Iota",
        "description": "Comment iota (displayed as text)"
    },
    "tab_indent": {
        "prefix": "tab_",
        "body": "tab_${1:4}",
        "label": "Tab Indent",
        "description": "Indent comment with linebreak + spaces"
    }
}
