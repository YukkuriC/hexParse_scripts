{
    "scopeName": "markdown.hexparse.codeblock.injection",
    "injectionSelector": "L:text.html.markdown",
    "patterns": [
        {
            "begin": "(?:^|\\G)(\\s*)(`{3,})(?:\\s*((?i:hex(?:[Pp]arse)))(?:[^\\n`]*)?)(\\s*$)",
            "beginCaptures": {
                "1": {
                    "name": "text.html.markdown"
                },
                "2": {
                    "name": "string.other.begin.code.fenced.markdown"
                },
                "3": {
                    "name": "entity.name.function.markdown"
                },
                "4": {
                    "name": "text.html.markdown"
                }
            },
            "end": "(?:^|\\G)(\\s*\\2)(\\s*$)",
            "endCaptures": {
                "1": {
                    "name": "string.other.end.code.fenced.markdown"
                },
                "2": {
                    "name": "text.html.markdown"
                }
            },
            "name": "markup.fenced_code.block.markdown",
            "contentName": "meta.embedded.block.hexparse",
            "patterns": [
                {
                    "include": "source.HexParse"
                }
            ]
        }
    ]
}