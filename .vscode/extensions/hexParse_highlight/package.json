{
    "name": "hexparse-highlight",
    "version": "1.1.0",
    "displayName": "%ext.displayName%",
    "description": "%ext.description%",
    "icon": "icon.webp",
    "license": "MIT",
    "keywords": [
        "hexcasting",
        "hexparse",
        "minecraft",
        "syntax-highlighting",
        "lsp"
    ],
    "engines": {
        "vscode": "^1.74.0"
    },
    "publisher": "YukkuriC",
    "repository": {
        "type": "git",
        "url": "https://github.com/YukkuriC/hexParse_scripts/tree/main/.vscode/extensions/hexParse_highlight"
    },
    "categories": [
        "Programming Languages"
    ],
    "activationEvents": [
        "onLanguage:HexParse"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "HexParse",
                "extensions": [
                    ".hexParse",
                    ".hexparse"
                ],
                "aliases": [
                    "HexParse",
                    "hexParse",
                    "hexparse"
                ],
                "icon": {
                    "dark": "icon.webp",
                    "light": "icon.webp"
                },
                "configuration": "./syntaxes/languageConfiguration.json"
            }
        ],
        "grammars": [
            {
                "language": "HexParse",
                "scopeName": "source.HexParse",
                "path": "./syntaxes/HexParse.tmGrammar.json"
            },
            {
                "scopeName": "markdown.hexparse.codeblock.injection",
                "path": "./syntaxes/HexParse-injection.tmLanguage.json",
                "injectTo": [
                    "text.html.markdown"
                ],
                "embeddedLanguages": {
                    "meta.embedded.block.hexparse": "HexParse"
                }
            }
        ],
        "snippets": [
            {
                "language": "HexParse",
                "path": "./snippets/hexparse.json"
            }
        ],
        "configuration": {
            "title": "HexParse",
            "properties": {
                "hexparse.lehmerTemplate": {
                    "type": "string",
                    "default": "({result})splat,swizzle",
                    "description": "%config.lehmerTemplate.description%"
                }
            }
        },
        "commands": [
            {
                "command": "hexparse.calculateLehmer",
                "title": "%command.lehmer.title%",
                "category": "HexParse"
            }
        ],
        "keybindings": [
            {
                "command": "hexparse.calculateLehmer",
                "key": "ctrl+shift+l",
                "when": "editorTextFocus && editorLangId == HexParse"
            }
        ]
    },
    "scripts": {
        "linkSelf": "node scripts/linkSelf.js",
        "compile": "npm run locale && npm run grammar && npm run generate-plugins && npm run final_compile",
        "locale": "node scripts/merge-jsons.js",
        "grammar": "node scripts/grammar.js",
        "generate-plugins": "node scripts/generate-plugins.js",
        "final_compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "reformat-jsons": "node scripts/reformat-jsons.js"
    },
    "devDependencies": {
        "@types/node": "^20.x",
        "@types/vscode": "^1.74.0",
        "js-yaml": "^4.2.0",
        "typescript": "^5.3.x"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1",
        "vscode-languageserver": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.11"
    }
}
