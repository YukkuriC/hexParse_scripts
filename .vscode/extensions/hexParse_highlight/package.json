{
    "name": "hexparse-highlight",
    "version": "1.0.0",
    "displayName": "HexParse Highlight Extension",
    "description": "Syntax highlighting, LSP (completion/hover/diagnostics), and snippets for HexParse script language.",
    "icon": "icon.webp",
    "license": "MIT",
    "keywords": [
        "hexcasting",
        "hexparse",
        "minecraft",
        "syntax-highlighting",
        "lsp"
    ],
    "engines": {
        "vscode": "^1.74.0"
    },
    "publisher": "YukkuriC",
    "repository": {
        "type": "git",
        "url": "https://github.com/YukkuriC/hexParse_scripts/tree/main/.vscode/extensions/hexParse_highlight"
    },
    "categories": [
        "Programming Languages"
    ],
    "activationEvents": [
        "onLanguage:HexParse"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "HexParse",
                "extensions": [
                    ".hexParse",
                    ".hexparse"
                ],
                "aliases": [
                    "HexParse",
                    "hexparse"
                ],
                "icon": {
                    "dark": "icon.webp",
                    "light": "icon.webp"
                },
                "configuration": "./syntaxes/languageConfiguration.json"
            }
        ],
        "grammars": [
            {
                "language": "HexParse",
                "scopeName": "source.HexParse",
                "path": "./syntaxes/HexParse.tmGrammar.json"
            }
        ],
        "snippets": [
            {
                "language": "HexParse",
                "path": "./snippets/hexparse.json"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run grammar && npm run compile",
        "grammar": "python syntaxes/parser.py",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node": "^20.x",
        "@types/vscode": "^1.74.0",
        "typescript": "^5.3.x"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1",
        "vscode-languageserver": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.11"
    }
}